  status TEXT [default: 'open']
  task_id TEXT
  completed INTEGER [default: 0]
  regressed INTEGER [default: 0]
  archived INTEGER [default: 0]
  created_at TEXT [default: CURRENT_TIMESTAMP]
  updated_at TEXT [default: CURRENT_TIMESTAMP]
  current_behavior TEXT [default: '']
  expected_behavior TEXT [default: '']
  work_item_type TEXT [default: 'software_bug']
  affected_module_keys TEXT [default: '[]']
}

Table credentials {
  id TEXT [pk]
  name TEXT [not null]
  host TEXT [not null]
