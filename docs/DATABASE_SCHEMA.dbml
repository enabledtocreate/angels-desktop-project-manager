Project "Angel's Project Manager" {
  database_type: "Generic"
}

Table app_settings {
  key TEXT [pk]
  value TEXT
  is_secret INTEGER [default: 0]
  updated_at TEXT [default: CURRENT_TIMESTAMP]
}

Table bug_items {
  id TEXT [pk]
  project_id TEXT [not null]
  code TEXT [not null]
