  },
  "engines": { "node": ">=18.0.0" },
  "devDependencies": {
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron": "^28.0.0",
    "express": "^4.18.2",
    "kill-port": "^1.1.0",
    "ssh2": "^1.17.0"
  }
}
